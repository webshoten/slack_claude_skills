{
  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "Deno: dev",
      "type": "node",
      "program": "${workspaceFolder}/main.ts",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "--watch",
        "--inspect",
        "--env",
        "--allow-net",
        "--allow-read",
        "--allow-env",
        "--unstable-kv"
      ],
      "attachSimplePort": 9229,
      "restart": true,
      "console": "integratedTerminal"
    }
  ]
}
